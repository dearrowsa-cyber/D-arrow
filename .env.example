# Email Configuration for Gmail (DarrowAppPass)

# Add these environment variables to:
# 1. Local development: Create .env.local file
# 2. Vercel: Project Settings > Environment Variables
# 3. Hostinger: Control Panel > Advanced > Environment Variables

CONTACT_RECIPIENT=d.arrow2026@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=d.arrow2026@gmail.com
SMTP_PASS=jcca sjrq eguq dogq
SMTP_FROM=d.arrow2026@gmail.com
SMTP_SECURE=false
SMTP_REJECT_UNAUTHORIZED=true

# Important Notes:
# - SMTP_PASS is the Gmail App Password (16 characters with spaces)
# - This is NOT your Gmail password
# - Generated from Gmail Security settings
# - Can be revoked anytime from account settings
# - Keep this secure and never commit to git
# N8N Chatbot Configuration
# Get your webhook URL from your N8N workflow configuration
# Format: https://your-n8n-instance.com/webhook/chat-webhook-id
# You can get this from N8N > Workflow > Webhook trigger > Copy webhook URL
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id