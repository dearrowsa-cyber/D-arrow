generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model SeoMeta {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String?
  description     String?
  focusKeyword    String?
  canonicalUrl    String?
  robots          String?  @default("index, follow") // e.g., "noindex, nofollow"
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  twitterCard     String?  @default("summary_large_image")
  schemaType      String?  @default("WebPage") // e.g., Article, Product, FAQ
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  auditLogs       SeoAuditLog[]
}

model SeoTemplate {
  id              String   @id @default(cuid())
  type            String   @unique // e.g., "post", "page", "product"
  titleTemplate   String   @default("{{title}} | {{site_name}}")
  descTemplate    String   @default("{{description}}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Redirect {
  id              String   @id @default(cuid())
  sourceUrl       String   @unique
  destinationUrl  String
  type            Int      @default(301) // 301 or 302
  enabled         Boolean  @default(true)
  hitCount        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model RobotsRule {
  id              String   @id @default(cuid())
  userAgent       String   @default("*")
  directive       String   // "Allow" or "Disallow"
  path            String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userAgent, path, directive])
}

model SchemaMarkup {
  id              String   @id @default(cuid())
  slug            String   @unique // The page slug to inject this into
  type            String   // e.g., "Article", "FAQPage"
  jsonData        String   // Stringified JSON-LD
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SeoAuditLog {
  id              String   @id @default(cuid())
  seoMetaId       String
  seoMeta         SeoMeta  @relation(fields: [seoMetaId], references: [id], onDelete: Cascade)
  score           Int
  issuesCount     Int
  suggestions     String   // Stringified JSON array of suggestions
  analyzedAt      DateTime @default(now())
}

model TrackedKeyword {
  id            String   @id @default(cuid())
  keyword       String   @unique
  group         String?
  starred       Boolean  @default(false)
  priority      String?  @default("medium")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rankings      KeywordRanking[]
  pageKeywords  PageKeyword[]
}

model KeywordRanking {
  id            String   @id @default(cuid())
  keywordId     String
  keyword       TrackedKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  position      Float
  clicks        Int      @default(0)
  impressions   Int      @default(0)
  ctr           Float    @default(0)
  date          DateTime
  createdAt     DateTime @default(now())

  @@unique([keywordId, date])
}

model PageKeyword {
  id            String   @id @default(cuid())
  keywordId     String
  keyword       TrackedKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  pageUrl       String
  position      Float
  clicks        Int      @default(0)
  impressions   Int      @default(0)
  date          DateTime
  createdAt     DateTime @default(now())

  @@unique([keywordId, pageUrl, date])
}


model BlogPost {
  id          String   @id @default(cuid())
  title       String
  titleAr     String?
  slug        String?  @unique // رابط المقالة المخصص — يُستخدم في الـ sitemap والـ URL
  content     String
  contentAr   String?
  excerpt     String?
  excerptAr   String?
  author      String   @default("D-Arrow")
  category    String   @default("Digital Marketing")
  categoryAr  String?
  date        String
  time        String
  readTime    Int      @default(1)
  imageUrl    String?
  status      String   @default("published")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// =============================================
// E-COMMERCE STORE MODELS
// =============================================

model Product {
  id              String   @id @default(cuid())
  name            String
  nameAr          String?
  slug            String   @unique
  description     String?
  descriptionAr   String?
  price           Float
  salePrice       Float?
  currency        String   @default("SAR")
  images          String?  // JSON array of image URLs
  category        String   @default("General")
  categoryAr      String?
  type            String   @default("digital") // digital, service, template, course
  downloadUrl     String?  // URL or file path for digital products
  features        String?  // JSON array of feature strings
  featuresAr      String?  // JSON array of Arabic feature strings
  status          String   @default("published") // published, draft
  featured        Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reviews         ProductReview[]
  orderItems      OrderItem[]
}

model Order {
  id              String   @id @default(cuid())
  orderNumber     String   @unique
  customerName    String
  customerEmail   String
  customerPhone   String?
  subtotal        Float
  discount        Float    @default(0)
  total           Float
  couponCode      String?
  paymentMethod   String   @default("bank_transfer") // stripe, bank_transfer, mada, stc_pay, tabby, tamara
  paymentStatus   String   @default("pending") // pending, paid, failed, refunded
  paymentIntentId String?  // Stripe payment intent ID
  status          String   @default("pending") // pending, processing, completed, cancelled
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items           OrderItem[]
}

model OrderItem {
  id              String   @id @default(cuid())
  orderId         String
  order           Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  productName     String
  price           Float
  quantity        Int      @default(1)
  total           Float
  createdAt       DateTime @default(now())
}

model Coupon {
  id              String    @id @default(cuid())
  code            String    @unique
  type            String    @default("percentage") // percentage, fixed
  value           Float     // discount value (e.g., 10 for 10% or 50 for 50 SAR)
  minOrder        Float?    // minimum order amount
  maxUses         Int?      // max number of uses (null = unlimited)
  usedCount       Int       @default(0)
  expiresAt       DateTime?
  active          Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model ProductReview {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerName    String
  customerEmail   String?
  rating          Int      // 1-5
  comment         String?
  approved        Boolean  @default(false)
  createdAt       DateTime @default(now())
}
